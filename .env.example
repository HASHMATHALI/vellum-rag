# Environment Variables Template
# Copy this file to .env and configure the fields.

# App Settings
PROJECT_NAME="RAG Semantic Search Platform"
ENVIRONMENT=development
DEBUG=true
PORT=8000

# Security and Auth
# Generate a secure secret key using: openssl rand -hex 32
JWT_SECRET_KEY=9a7c3d2e9b8f5a1c0d4e3f2a1b6c7d8e9f0a1b2c3d4e5f6a7b8c9d0e1f2a3b4c
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database Settings (PostgreSQL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_password_change_me
POSTGRES_DB=rag_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres_password_change_me@postgres:5432/rag_db

# Cache Settings (Redis)
REDIS_URL=redis://redis:6379/0

# Groq API Key for LLM Responses
# Get one from: https://console.groq.com/
GROQ_API_KEY=gsk_your_groq_api_key_goes_here

# Vector Store Path
VECTOR_STORE_DIR=/app/vector_store

# Ingestion Settings
CHUNK_SIZE=500
CHUNK_OVERLAP=50
MAX_UPLOAD_SIZE_MB=20
